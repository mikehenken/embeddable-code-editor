{
  "name": "@mikehenken/embedacode",
  "version": "2.1.0",
  "description": "Read-only code viewer web component for blogs and docs: embed snippets or multi-file trees via JSON (no GitHub required), or optionally load a public GitHub repo. Lit + Prism, shadow-DOM scoped.",
  "type": "module",
  "main": "./dist/embedacode.umd.js",
  "module": "./dist/embedacode.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/embedacode.es.js",
      "require": "./dist/embedacode.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./standalone": "./dist/embedacode.standalone.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mikehenken/embedacode.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && tsc -p tsconfig.build.json && vite build && vite build -c vite.standalone.config.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "keywords": [
    "web-component",
    "lit",
    "prismjs",
    "syntax-highlighter",
    "code-editor",
    "embedacode",
    "github",
    "documentation",
    "blog",
    "tutorial",
    "code-snippets"
  ],
  "license": "MIT",
  "dependencies": {
    "jszip": "^3.10.1",
    "lit": "^3.3.2",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/dom": "^10.4.1",
    "@types/jszip": "^3.4.0",
    "@types/prismjs": "^1.26.6",
    "eslint": "^9.17.0",
    "jsdom": "^29.0.0",
    "serve": "^14.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
